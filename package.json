{
  "name": "retroppies-photobooth",
  "version": "0.1.1",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:build": "tsc && vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "ffmpeg-static": "^5.3.0",
    "fix-webm-duration": "^1.0.6",
    "framer-motion": "^11.2.10",
    "gifenc": "^1.0.3",
    "idb-keyval": "^6.2.5",
    "qrcode": "^1.5.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-webcam": "^7.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.retroppies.photobooth",
    "productName": "Retroppies Photobooth",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/ffmpeg-static/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/print-borderless.ps1",
        "to": "print-borderless.ps1"
      },
      {
        "from": "build/updater.ps1",
        "to": "updater.ps1"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Retroppies Photobooth",
      "include": "build/installer.nsh",
      "artifactName": "Retroppies-Photobooth-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "luthfikamalananda",
        "repo": "retroppies-photobooth",
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": "dmg"
    }
  }
}
